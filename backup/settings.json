          {
            "type": "command",
            "command": "node C:/Users/JNaidu/.claude/hooks/mp/session-start.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/JNaidu/.claude/hooks/tp-session-start.mjs",
            "timeout": 10
          }
        ]
      }
